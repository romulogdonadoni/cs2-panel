# Cópia para .env e preenche. NUNCA fazer commit de .env.
# GSLT: https://steamcommunity.com/dev/managegameservers
SRCDS_TOKEN=your_token_here
CS2_SERVERNAME=My CS2 Server
CS2_STARTMAP=de_dust2
CS2_MAPGROUP=mg_active
CS2_GAMETYPE=0
CS2_GAMEMODE=1
CS2_MAXPLAYERS=12
CS2_RCONPW=changeme
CS2_PW=
# ID (só dígitos) de um mapa da Workshop para o servidor pedir o download no arranque; depois de alterar, reiniciar o contentor cs2.
# Se o in-game continuar com pasta 730 vazia, no host: ./scripts/workshop-steamcmd-download.sh <id> (Docker) e recomeçar a partida.
CS2_HOST_WORKSHOP_MAP=
CS2_HOST_WORKSHOP_COLLECTION=
# Argumentos extra do workshop (imagem cm2network/cs2); vazio se não usas collection.
CS2_HOST_WORKSHOP_COLLECTION_ARGS=
CS2_GAMEALIAS=

# Steam Web API (https://steamcommunity.com/dev/apikey) — avatar no painel, API workshop no painel
# e, via docker-compose, -authkey no processo do servidor (download de mapas workshop / MatchZy).
STEAM_WEB_API_KEY=your_steam_web_api_key

# SteamCMD: 1 = validar ficheiros do jogo no arranque (correção; mais lento). Default 0.
STEAMAPPVALIDATE=0

# Painel
PANEL_PORT=3080
# Base URL pública (Steam OpenId, lobbies, webhooks). Local:
PANEL_BASE_URL=http://127.0.0.1:3080
# Produção (ex.: Nginx: deploy/nginx-painel-exemplo.conf):
# PANEL_BASE_URL=https://romulogdonadoni.com.br
SESSION_SECRET=gerar_uma_string_longa_aleatoria
LOADOUT_API_KEY=gerar_outra_chave_secreta
PANEL_DATA_DIR=./data
PANEL_COMPOSE_DIR=.
# Obrigatório em produção: define um segredo e usa o MESMO em matchzy_remote_log_header_value (MatchZy).
# POST /api/webhooks/matchzy-events requer x-matchzy-secret (ou Authorization: Bearer) alinhado.
# MATCHZY_WEBHOOK_SECRET=um_segredo_longo_aleatorio

# Prisma (SQLite). Em `docker compose` o compose define `DATABASE_URL=file:/data/panel.db`.
# Desenvolvimento local em `panel/`: podes usar `file:./prisma/dev.db` (ver `panel/.env`).
# DATABASE_URL=file:./panel/prisma/dev.db

# Opcional: só estes SteamID64 podem editar o painel (vírgula). Vazio = qualquer user autenticado.
ADMIN_STEAMID64S=

# Opcional: FACEIT Data API — mostra Lv e Elo CS2 no lobby. Chave em https://developers.faceit.com/
# (a conta FACEIT precisa de email verificado e MFA ativo para criar app / API key)
# FACEIT_API_KEY=
